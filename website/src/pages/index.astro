---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-8 pt-20 pb-16">
    <div class="grid grid-cols-5 gap-16 items-start">
      <div class="col-span-3">
        <p class="text-sm font-medium text-stone-400 tracking-widest uppercase mb-6">Ballwin, Missouri</p>
        <h1 class="text-5xl font-light text-stone-900 leading-tight mb-6">
          Tim Mattingly
        </h1>
        <p class="text-xl text-stone-500 font-light leading-relaxed mb-8">
          I learn things. Then I build things with what I learned.
        </p>
        <p class="text-base text-stone-600 leading-relaxed max-w-xl">
          Thirty years of building companies, leading technology teams, and figuring out what comes next.
          EE undergrad. 4.0 MBA. Three patents. Currently shipping software without writing code —
          and teaching AI agents to do it reliably.
        </p>
        <div class="flex items-center gap-4 mt-10">
          <a href="/work" class="inline-flex items-center gap-2 bg-stone-900 text-white px-6 py-3 text-sm font-medium hover:bg-stone-700 transition-colors">
            See the work
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 border border-stone-300 text-stone-700 px-6 py-3 text-sm font-medium hover:border-stone-900 transition-colors">
            Get in touch
          </a>
        </div>
      </div>
      <div class="col-span-2">
        <!-- Headshot placeholder -->
        <div class="aspect-[3/4] bg-stone-100 flex items-end justify-center">
          <p class="text-stone-400 text-xs pb-4">Photo coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Facet grid -->
  <section class="max-w-6xl mx-auto px-8 py-16 border-t border-stone-100">
    <div class="grid grid-cols-4 gap-px bg-stone-200">

      <a href="/work#founder" class="bg-white p-8 hover:bg-stone-50 transition-colors group">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-4">Founder</p>
        <h2 class="text-lg font-medium text-stone-900 mb-3 group-hover:text-stone-600 transition-colors">
          Built companies
        </h2>
        <p class="text-sm text-stone-500 leading-relaxed">
          Equilliance to 300 people. 5 subsidiaries. Acquired 4 competitors.
          Then, 25 years later, built a production SaaS — without writing a line of code.
        </p>
      </a>

      <a href="/work#engineer" class="bg-white p-8 hover:bg-stone-50 transition-colors group">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-4">Engineer</p>
        <h2 class="text-lg font-medium text-stone-900 mb-3 group-hover:text-stone-600 transition-colors">
          Built the system
        </h2>
        <p class="text-sm text-stone-500 leading-relaxed">
          Smarter Travel Planner is live. So is the AI orchestration layer that built it —
          sprint planning, quality gates, automated deployment, failure recovery.
        </p>
      </a>

      <a href="/work#advisor" class="bg-white p-8 hover:bg-stone-50 transition-colors group">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-4">Advisor</p>
        <h2 class="text-lg font-medium text-stone-900 mb-3 group-hover:text-stone-600 transition-colors">
          Built careers for others
        </h2>
        <p class="text-sm text-stone-500 leading-relaxed">
          Mastercard VP. Centene Senior Director. Now advising health tech startups at BioSTL
          with 75+ executive-level advisors.
        </p>
      </a>

      <a href="/work#community" class="bg-white p-8 hover:bg-stone-50 transition-colors group">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-4">Community</p>
        <h2 class="text-lg font-medium text-stone-900 mb-3 group-hover:text-stone-600 transition-colors">
          HOA President
        </h2>
        <p class="text-sm text-stone-500 leading-relaxed">
          Yes, also that. Turns out the skills transfer:
          stakeholders are stakeholders, budgets are budgets.
        </p>
      </a>
    </div>
  </section>

  <!-- The work + travel row -->
  <section class="max-w-6xl mx-auto px-8 py-8">
    <div class="grid grid-cols-3 gap-8">

      <!-- Patents — credibility stack -->
      <div class="col-span-1 border border-stone-200 p-8">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-6">Patents</p>
        <div class="space-y-6">
          <div>
            <p class="text-xs text-stone-400 mb-1">US11062038B2 · 2021</p>
            <p class="text-sm text-stone-700 leading-snug">Identity & Credential Protection via Blockchain</p>
          </div>
          <div>
            <p class="text-xs text-stone-400 mb-1">US20170004486A1</p>
            <p class="text-sm text-stone-700 leading-snug">Fraud Control Based on Geolocation</p>
          </div>
          <div>
            <p class="text-xs text-stone-400 mb-1">US20170270493A1</p>
            <p class="text-sm text-stone-700 leading-snug">Point-to-Point Transaction Processing</p>
          </div>
        </div>
      </div>

      <!-- Travel preview -->
      <a href="/travel" class="col-span-2 border border-stone-200 p-8 hover:bg-stone-50 transition-colors group">
        <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-6">Our Travels — Tim & Jill</p>
        <div class="grid grid-cols-2 gap-6 items-start">
          <div>
            <h3 class="text-lg font-medium text-stone-900 mb-2 group-hover:text-stone-600 transition-colors">
              Ljubljana, Slovenia
            </h3>
            <p class="text-xs text-stone-400 mb-3">May 31 – June 10, 2025</p>
            <p class="text-sm text-stone-500 leading-relaxed">
              "The Ljubljanica River was the first thing that stopped me in my tracks —
              that impossible emerald green, like someone had dissolved a gemstone into the water."
            </p>
          </div>
          <div class="aspect-video bg-stone-100 flex items-center justify-center">
            <p class="text-stone-400 text-xs">Photo coming soon</p>
          </div>
        </div>
        <p class="text-sm text-stone-400 mt-6 group-hover:text-stone-600 transition-colors">More journals →</p>
      </a>
    </div>
  </section>

  <!-- Now strip -->
  <section class="max-w-6xl mx-auto px-8 py-8">
    <div class="border border-stone-200 p-8">
      <div class="grid grid-cols-4 gap-8 items-start">
        <div>
          <p class="text-xs font-medium text-stone-400 tracking-widest uppercase mb-3">Now</p>
          <p class="text-sm text-stone-500">April 2026</p>
        </div>
        <div class="col-span-3">
          <p class="text-base text-stone-600 leading-relaxed">
            Shipping the last features on Smarter Travel Planner before demo season.
            Advising health tech startups through BioSTL. Planning the next trip.
            Building toward a life that works from a café in Porto as easily as it does from Ballwin.
          </p>
          <a href="/now" class="text-sm text-stone-400 hover:text-stone-700 transition-colors mt-3 inline-block">Full update →</a>
        </div>
      </div>
    </div>
  </section>
</Base>
