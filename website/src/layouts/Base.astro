---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Tim Mattingly',
  description = 'Founder. Engineer. Advisor. Husband. Occasional HOA President.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title === 'Tim Mattingly' ? title : `${title} — Tim Mattingly`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-stone-100">
      <div class="max-w-6xl mx-auto px-8 py-4 flex items-center justify-between">
        <a href="/" class="text-stone-900 font-medium tracking-tight hover:text-stone-600 transition-colors">
          Tim Mattingly
        </a>
        <div class="flex items-center gap-8 text-sm text-stone-500">
          <a href="/work" class="hover:text-stone-900 transition-colors">Work</a>
          <a href="/travel" class="hover:text-stone-900 transition-colors">Our Travels</a>
          <a href="/now" class="hover:text-stone-900 transition-colors">Now</a>
          <a href="/contact" class="hover:text-stone-900 transition-colors">Contact</a>
        </div>
      </div>
    </nav>
    <main class="pt-16">
      <slot />
    </main>
    <footer class="mt-24 border-t border-stone-100 py-8">
      <div class="max-w-6xl mx-auto px-8 flex items-center justify-between text-sm text-stone-400">
        <span>Tim Mattingly</span>
        <div class="flex items-center gap-6">
          <a href="https://linkedin.com/in/timothywmattingly" class="hover:text-stone-600 transition-colors">LinkedIn</a>
          <a href="https://calendly.com/timmattingly" class="hover:text-stone-600 transition-colors">Calendly</a>
        </div>
      </div>
    </footer>
  </body>
</html>
